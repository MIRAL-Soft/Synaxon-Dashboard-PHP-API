# Copy this file to tests/.env.test and fill in real values to enable
# the integration test suite. Without these, integration tests are skipped.

# Master switch — must equal 1 for any integration test to run.
SYNAXON_INTEGRATION=0

# API base URI (override only if you target a sandbox).
SYNAXON_BASE_URI=https://api.synaxon.com/marketplace

# Authentication — supply EITHER a bearer token OR basic credentials.
SYNAXON_BEARER_TOKEN=
SYNAXON_BASIC_USER=
SYNAXON_BASIC_PASS=
