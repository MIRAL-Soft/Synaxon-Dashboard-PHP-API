# Copy this file to tests/.env.test and fill in real values to enable
# the integration test suite. Without credentials, integration tests are
# skipped automatically.

# API base URI (override only if you target a sandbox).
SYNAXON_BASE_URI=https://api.synaxon.com/marketplace

# Authentication.
#
# Supply EITHER:
#  - a long-lived bearer token (preferred, skips the login round-trip), OR
#  - basic credentials. The test suite will exchange them for a bearer
#    token via POST /v1/auth/token and cache the result in
#    tests/.bearer-token.cache (gitignored) until it expires.
SYNAXON_BEARER_TOKEN=
SYNAXON_BASIC_USER=
SYNAXON_BASIC_PASS=

# OAuth2 scope used when exchanging basic credentials for a bearer token.
# Defaults to "sys-app"; set to "sys-app-beta" to target the beta scope.
SYNAXON_SCOPE=
