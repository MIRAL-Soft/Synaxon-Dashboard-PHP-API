{
    "name": "miralsoft/synaxon-api",
    "description": "A professional PHP client library for the SYNAXON Marketplace REST API.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Michael Tosch",
            "email": "m.tosch@miralsoft.com",
            "role": "Software Engineer"
        }
    ],
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "autoload": {
        "psr-4": {
            "miralsoft\\synaxon\\api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "miralsoft\\synaxon\\api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite Unit --testdox",
        "test:integration": "phpunit --testsuite Integration --testdox",
        "test:all": "phpunit --testdox",
        "analyse": "phpstan analyse src --level=8",
        "check-compat": "php bin/check-api-compat.php",
        "fmt": "php-cs-fixer fix",
        "fmt:check": "php-cs-fixer fix --dry-run --diff",
        "ci": [
            "@fmt:check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
